---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map(character => ({
    params: { slug: character.id },
    props: { character },
  }));
}

const { character } = Astro.props;
const { Content } = await render(character);

const ACCENT: Record<string, string> = {
  'mara-embervale': 'oklch(48% 0.14 18)',
  'wynn':           'oklch(52% 0.10 128)',
  'nyssara':        'oklch(56% 0.09 255)',
  'querc':          'oklch(52% 0.11 148)',
  'tom-evenwood':   'oklch(54% 0.11 48)',
};

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

const accentColor = ACCENT[character.id] ?? 'var(--gold)';
const tagline = `${character.data.race} · ${character.data.class_name}`;

const portraitModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/characters/*.png',
  { eager: true }
);
const portrait = portraitModules[`/src/content/characters/${character.id}.png`]?.default;
---

<BaseLayout title={character.data.name}>
  <div class="detail-page" style={`--char-accent: ${accentColor}`}>
    <div class="page-wrap">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={resolveHref('/characters')}>Characters</a>
        <span class="breadcrumb__sep" aria-hidden="true">›</span>
        <span>{character.data.name}</span>
      </nav>

      <div class="detail-layout">

        <div class="detail-left">
          <div class="detail-portrait">
            {portrait ? (
              <Image
                src={portrait}
                alt={character.data.name}
                class="detail-portrait__img"
                width={600}
                height={800}
              />
            ) : (
              <div class="detail-portrait__placeholder" aria-hidden="true">
                {character.data.name[0]}
              </div>
            )}
          </div>

          <dl class="detail-stat-block">
            <div class="detail-stat-row">
              <dt>Race</dt>
              <dd>{character.data.race}</dd>
            </div>
            <div class="detail-stat-row">
              <dt>Class</dt>
              <dd>{character.data.class_name}</dd>
            </div>
            <div class="detail-stat-row">
              <dt>Player</dt>
              <dd>{character.data.player}</dd>
            </div>
          </dl>
        </div>

        <div class="detail-right">
          <h1 class="detail-name">{character.data.name}</h1>
          <p class="detail-tagline">{tagline}</p>

          <div class="detail-rule" aria-hidden="true">
            <div class="detail-rule__line"></div>
            <span class="detail-rule__mark">✦</span>
            <div class="detail-rule__line"></div>
          </div>

          <blockquote class="detail-bio">{character.data.short_bio}</blockquote>

          <div class="detail-prose">
            <Content />
          </div>

        </div>

      </div>
    </div>
  </div>
</BaseLayout>
