---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const characters = await getCollection('characters');

const portraitModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/characters/*.png',
  { eager: true }
);
const portraits: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(portraitModules).map(([path, mod]) => [
    path.replace('/src/content/characters/', '').replace('.png', ''),
    mod.default,
  ])
);

const order = { active: 0, inactive: 1, deceased: 2 };
const sorted = characters.sort((a, b) =>
  (order[a.data.status] ?? 99) - (order[b.data.status] ?? 99)
);

const ACCENT: Record<string, string> = {
  'mara-embervale': 'oklch(48% 0.14 18)',
  'wynn':           'oklch(52% 0.10 128)',
  'nyssara':        'oklch(56% 0.09 255)',
  'querc':          'oklch(52% 0.11 148)',
  'tom-evenwood':   'oklch(54% 0.11 48)',
};

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}
---

<BaseLayout title="Characters" description="The founding members of the Solis Lantern adventuring guild.">
  <div class="roster-page">
    <div class="roster-header">
      <div>
        <p class="roster-header__eyebrow">The Party</p>
        <h1 class="roster-header__title">Characters</h1>
      </div>
    </div>

    <ul class="roster-grid">
      {sorted.map(character => (
        <li>
          <a
            href={resolveHref(`/characters/${character.id}`)}
            class="roster-card"
            style={`--char-accent: ${ACCENT[character.id] ?? 'var(--gold)'}`}
          >
            <div class="roster-card__portrait-wrap">
              <div class="roster-card__portrait">
                {portraits[character.id] ? (
                  <Image
                    src={portraits[character.id]}
                    alt={character.data.name}
                    width={400}
                    height={533}
                  />
                ) : (
                  <span class="roster-card__portrait-initial" aria-hidden="true">
                    {character.data.name[0]}
                  </span>
                )}
              </div>
              <div class="roster-card__overlay">
                <span class="roster-card__overlay-text">View Profile</span>
              </div>
            </div>
            <div class="roster-card__info">
              <span class="roster-card__name">{character.data.name}</span>
              <span class="roster-card__class">{character.data.class_name}</span>
              <span class="roster-card__player">{character.data.player}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
