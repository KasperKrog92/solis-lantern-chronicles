---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const loreEntries = await getCollection('lore');
  return loreEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allLore = await getCollection('lore');
const relatedEntries = entry.data.related
  ? allLore.filter(e => entry.data.related!.includes(e.id))
  : [];

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

const categoryLabels: Record<string, string> = {
  location: 'Location',
  faction:  'Faction',
  concept:  'Concept',
  creature: 'Creature',
};
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="lore-entry-wrap">

    <nav class="breadcrumb">
      <a href={resolveHref('/world')}>World</a>
      <span class="breadcrumb__sep">&rsaquo;</span>
      <span>{entry.data.title}</span>
    </nav>

    <div class="entry-wrap">

      <div class="entry-body">
        <p class="entry-cat" data-cat={entry.data.category}>{categoryLabels[entry.data.category]}</p>
        <h1 class="entry-title">{entry.data.title}</h1>

        <div class="entry-rule">
          <div class="entry-rule__line"></div>
          <span class="entry-rule__mark">&#10022;</span>
          <div class="entry-rule__line"></div>
        </div>

        <blockquote class="entry-summary">{entry.data.summary}</blockquote>

        <div class="entry-prose">
          <Content />
        </div>
      </div>

      <aside class="entry-sidebar">
        <div class="sidebar-block">
          <p class="sidebar-block__heading">Classification</p>
          <dl>
            <div class="sidebar-meta-row">
              <dt>Category</dt>
              <dd><span class="cat-badge" data-cat={entry.data.category}>{categoryLabels[entry.data.category]}</span></dd>
            </div>
          </dl>
        </div>

        {relatedEntries.length > 0 && (
          <div class="sidebar-block">
            <p class="sidebar-block__heading">Related Entries</p>
            <ul class="sidebar-related-list">
              {relatedEntries.map(rel => (
                <li>
                  <a href={resolveHref(`/lore/${rel.id}`)}>{rel.data.title}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>

    </div>
  </div>
</BaseLayout>
