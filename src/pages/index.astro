---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterChip from '../components/CharacterChip.astro';
import { getCollection } from 'astro:content';

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

// Three most recent non-draft chapters
const allChapters = await getCollection('chapters');
const recent = allChapters
  .filter(c => !c.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Character map for chips
const characters = await getCollection('characters');
const charMap = Object.fromEntries(characters.map(c => [c.id, c.data]));
---

<BaseLayout
  title="Solis Lantern Chronicles"
  description="A campaign chronicle for an ongoing homebrew TTRPG campaign set in a world shaped by Leviathans and the Great Walls."
>
  <div class="home-hero">
    <p class="home-hero__eyebrow">A Campaign Chronicle</p>
    <h1 class="home-hero__title">Solis Lantern Chronicles</h1>
    <p class="home-hero__intro">
      At the edge of the Middle Tier, where the Wall meets the city of gates,
      five strangers became something else. This is where their story is kept.
    </p>
    <div class="home-hero__cta">
      <a href={resolveHref('/chronicle')} class="btn btn--primary">Read the Chronicle</a>
      <a href={resolveHref('/world')} class="btn">The World</a>
    </div>

    {recent.length > 0 && (
      <div class="recent-section">
        <p class="recent-section__heading">Recent Sessions</p>
        <ul class="chapter-list">
          {recent.map(chapter => (
            <li class="chapter-card">
              <p class="chapter-card__session">
                Session {String(chapter.data.session).padStart(2, '0')}
              </p>
              <h2 class="chapter-card__title">
                <a href={resolveHref(`/chronicle/${chapter.id}`)}>{chapter.data.title}</a>
              </h2>
              <p class="chapter-card__date">
                {chapter.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              <p class="chapter-card__summary">{chapter.data.summary}</p>
              <div class="chapter-card__characters">
                {chapter.data.characters_present.map(slug => (
                  <CharacterChip slug={slug} name={charMap[slug]?.name ?? slug} />
                ))}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="about-section">
      <p class="about-section__heading">About this chronicle</p>
      <div class="about-section__body">
        <p>Solis Lantern Chronicles is a campaign chronicle: a record of an ongoing tabletop RPG campaign, written up as a narrative artifact after each session. It is made by a group of friends: a GM and five players, meeting regularly to tell a story together. New chapters appear when sessions happen.</p>
        <p>The setting is inspired by Robert Jackson Bennett's Shadow of the Leviathan book series, a world built around Leviathans, great walls, and a civilization organized around annual catastrophe. The world here has been reshaped considerably to fit a D&amp;D tabletop game: new factions, new rules, new characters, and a story that now belongs to the people playing it.</p>
        <p>The site is designed as a reading experience, something closer to a book than a blog. If you're new, start with the <a href={resolveHref('/chronicle')}>Chronicle</a>.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-section {
    width: 100%;
    max-width: 680px;
    margin: 4rem auto 0;
    text-align: left;
  }

  .about-section__heading {
    font-family: var(--font-sc);
    font-size: 1.05rem;
    letter-spacing: 0.28em;
    color: rgba(200, 168, 75, 0.5);
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(200, 168, 75, 0.16);
  }

  .about-section__body p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: rgba(200, 168, 75, 0.45);
    margin-bottom: 1.1rem;
  }

  .about-section__body p:last-child {
    margin-bottom: 0;
  }

  .about-section__body a {
    color: rgba(200, 168, 75, 0.65);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .about-section__body a:hover {
    color: rgba(200, 168, 75, 0.9);
  }
</style>
