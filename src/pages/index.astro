---
import BaseLayout from '../layouts/BaseLayout.astro';
import CharacterChip from '../components/CharacterChip.astro';
import { Image } from 'astro:assets';
import lanternLogo from '../assets/lantern-logo-new.png';
import { getCollection } from 'astro:content';

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

// Most recent non-draft chapter for spotlight
const allChapters = await getCollection('chapters');
const latest = allChapters
  .filter(c => !c.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

function extractOpening(body: string): string {
  // Drop import lines
  const noImports = body.replace(/^import .+$/gm, '');
  // Take only up to the first --- page break
  const firstBlock = noImports.split(/\n---(\n|$)/)[0];
  // Strip self-closing JSX tags (<Ambience .../> etc.)
  const noSelfClose = firstBlock.replace(/<[A-Z][^>]*\/>/g, '');
  // Strip JSX tags but keep inner text (<Lore slug="...">text</Lore> → text)
  const noTags = noSelfClose.replace(/<[A-Z][^>]*>([\s\S]*?)<\/[A-Z][^>]*>/g, '$1');
  const text = noTags.replace(/\s+/g, ' ').trim();
  // Keep only the first 3 sentences
  const sentences = text.match(/[^.!?]+[.!?]+/g) ?? [text];
  return sentences.slice(0, 2).join(' ').trim();
}

// Character map for chips
const characters = await getCollection('characters');
const charMap = Object.fromEntries(characters.map(c => [c.id, c.data]));
---

<BaseLayout
  title="Solis Lantern Chronicles"
  description="A campaign chronicle for an ongoing homebrew TTRPG campaign set in a world shaped by Leviathans and the Great Walls."
  fullscreenHero={true}
>
  <section class="hero">
    <div class="hero__content">
      <div class="hero__logo-wrap">
        <div class="hero__glow" aria-hidden="true"></div>
        <Image src={lanternLogo} alt="The Solis Lantern" class="hero__logo" loading="eager" />
      </div>
      <p class="hero__eyebrow">A Campaign Chronicle</p>
      <h1 class="hero__title">Solis Lantern Chronicles</h1>
      <p class="hero__ornament">— ✦ —</p>
      <p class="hero__intro">
        At the edge of the Middle Tier, where the Wall meets the city of gates,
        five strangers became something else. This is where their story is kept.
      </p>
      <div class="hero__cta">
        <a href={resolveHref('/chronicle')} class="btn btn--primary">Read the Chronicle</a>
        <a href={resolveHref('/world')} class="btn">The World</a>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

    {latest && (
      <section class="spotlight">
        <p class="spotlight__label">Latest Session</p>
        <div class="spotlight__card">
            <p class="spotlight__session-no">Session {String(latest.data.session).padStart(2, '0')}</p>
          <h2 class="spotlight__chapter-title">{latest.data.title}</h2>
          <p class="spotlight__date">
            {latest.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
          <div class="spotlight__divider" aria-hidden="true">
            <div class="spotlight__divider-line"></div>
            <span class="spotlight__divider-ornament">✦</span>
            <div class="spotlight__divider-line"></div>
          </div>
          <p class="spotlight__excerpt">{extractOpening(latest.body ?? '')}</p>
          <div class="spotlight__chars">
            {latest.data.characters_present.map(slug => (
              <CharacterChip slug={slug} name={charMap[slug]?.name ?? slug} />
            ))}
          </div>
          <a href={resolveHref(`/chronicle/${latest.id}`)} class="spotlight__read-link">Read this session →</a>
        </div>
      </section>
    )}

    <section class="about">
      <p class="about__ornament">— ✦ —</p>
      <div class="about__body">
        <p>Solis Lantern Chronicles is a campaign chronicle: a record of an ongoing tabletop RPG campaign, written up as a narrative artefact after each session. It is made by a group of friends, a GM and five players, meeting regularly to tell a story together.</p>
        <p>The setting draws on Robert Jackson Bennett's <em>Shadow of the Leviathan</em> series, reshaped considerably for a D&amp;D tabletop game with new factions, new rules, and a story that now belongs to the people playing it. If you're new, start with the <a href={resolveHref('/chronicle')}>Chronicle</a>.</p>
      </div>
    </section>
</BaseLayout>


<script>
  import { randomiseParchment } from '../scripts/parchment.js';
  const card = document.querySelector('.spotlight__card') as HTMLElement | null;
  if (card) randomiseParchment(card);
</script>

<style>
  .about {
    max-width: 680px;
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    text-align: center;
  }

  .about__ornament {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    padding-left: 0.4em;
    color: rgba(200, 168, 75, 0.2);
    margin-bottom: 2rem;
  }

  .about__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.9;
    color: rgba(200, 168, 75, 0.38);
  }

  .about__body p { margin-bottom: 1em; }
  .about__body p:last-child { margin-bottom: 0; }

  .about__body a {
    color: rgba(200, 168, 75, 0.55);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .about__body a:hover { color: rgba(200, 168, 75, 0.8); }
</style>
