---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CharacterChip from '../../components/CharacterChip.astro';
import { getCollection } from 'astro:content';

const allChapters = await getCollection('chapters');

const published = allChapters
  .filter(c => !c.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const drafts = allChapters
  .filter(c => c.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const chapters = [...published, ...drafts];

const characters = await getCollection('characters');
const charMap = Object.fromEntries(characters.map(c => [c.id, c.data]));

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}
---

<BaseLayout title="Chronicle" description="All sessions of the Solis Lantern Chronicles, newest first.">
  <div class="chronicle-page">

    <div class="world-header">
      <div class="world-header__left">
        <p class="world-header__eyebrow">Session Log</p>
        <h1 class="world-header__title">Chronicle</h1>
        <p class="world-header__intro">
          A record of every session. What was done, what was lost, and what the party
          would rather forget.
        </p>
      </div>
    </div>

    <div id="resume-banner" class="resume-banner" hidden>
      <span class="resume-banner__label">Continue Reading</span>
      <span class="resume-banner__title"></span>
      <span class="resume-banner__page"></span>
      <a class="resume-banner__link" href="">Resume →</a>
    </div>

    <div class="chapter-list-wrap">
      {chapters.length === 0 ? (
        <p style="color: rgba(200,168,75,0.45); font-style: italic;">
          The first pages are being written.
        </p>
      ) : (
        <ul class="chapter-list">
          {chapters.map(chapter => (
            <li class="chapter-card" data-chapter-path={resolveHref(`/chronicle/${chapter.id}`)}>
              <p class="chapter-card__session">
                Session {String(chapter.data.session).padStart(2, '0')}
                {chapter.data.draft && <span class="chapter-card__draft">[draft]</span>}
              </p>
              <h2 class="chapter-card__title">{chapter.data.title}</h2>
              <p class="chapter-card__date">
                {chapter.data.date.toLocaleDateString('en-GB', {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                })}
              </p>
              <div class="chapter-card__divider" aria-hidden="true">
                <div class="chapter-card__divider-line"></div>
                <span class="chapter-card__divider-gem">✦</span>
                <div class="chapter-card__divider-line"></div>
              </div>
              <p class="chapter-card__summary">{chapter.data.summary}</p>
              <div class="chapter-card__characters">
                {chapter.data.characters_present.map(slug => (
                  <CharacterChip slug={slug} name={charMap[slug]?.name ?? slug} />
                ))}
              </div>
              <span class="chapter-card__status" hidden>✓ Read</span>
              <div class="chapter-card__links">
                <a href={resolveHref(`/chronicle/${chapter.id}`)} class="chapter-card__read-link">Read this session →</a>
                <a href={resolveHref(`/chronicle/${chapter.id}`) + '#page-0'} class="chapter-card__restart-link" hidden>From beginning</a>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>

    <p class="chronicle-reset">
      <button id="reset-progress-btn" class="chronicle-reset__btn">Reset reading history</button>
    </p>

  </div>
</BaseLayout>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.chapter-card[data-chapter-path]');
  let resumeCandidate: { path: string; title: string; page: number } | null = null;

  for (const card of cards) {
    const path = card.dataset.chapterPath!;
    const completed  = localStorage.getItem(`chapter-completed:${path}`) === 'true';
    const savedPage  = parseInt(localStorage.getItem(`reading-progress:${path}`) ?? '', 10);
    const inProgress = !completed && savedPage > 0;

    const readLink    = card.querySelector<HTMLAnchorElement>('.chapter-card__read-link')!;
    const restartLink = card.querySelector<HTMLAnchorElement>('.chapter-card__restart-link')!;
    const statusEl    = card.querySelector<HTMLElement>('.chapter-card__status')!;

    if (completed) {
      card.classList.add('chapter-card--read');
      readLink.href        = `${path}#page-0`;
      readLink.textContent = 'Re-read →';
      statusEl.hidden      = false;
    } else if (inProgress) {
      card.classList.add('chapter-card--in-progress');
      readLink.href        = `${path}#page-${savedPage}`;
      readLink.textContent = 'Continue reading →';
      restartLink.hidden   = false;
      if (!resumeCandidate) {
        const title = card.querySelector('.chapter-card__title')?.textContent ?? '';
        resumeCandidate = { path, title, page: savedPage };
      }
    }
  }

  if (resumeCandidate) {
    const banner  = document.getElementById('resume-banner')!;
    banner.querySelector('.resume-banner__title')!.textContent  = resumeCandidate.title;
    banner.querySelector('.resume-banner__page')!.textContent   = `Page ${resumeCandidate.page}`;
    const link = banner.querySelector<HTMLAnchorElement>('.resume-banner__link')!;
    link.href = `${resumeCandidate.path}#page-${resumeCandidate.page}`;
    banner.hidden = false;
  }

  const resetBtn = document.getElementById('reset-progress-btn') as HTMLButtonElement;
  let resetArmed = false;
  let resetTimeout: ReturnType<typeof setTimeout>;

  resetBtn.addEventListener('click', () => {
    if (resetArmed) {
      clearTimeout(resetTimeout);
      for (let i = localStorage.length - 1; i >= 0; i--) {
        const key = localStorage.key(i)!;
        if (key.startsWith('reading-progress:') || key.startsWith('chapter-completed:')) {
          localStorage.removeItem(key);
        }
      }
      location.reload();
    } else {
      resetArmed = true;
      resetBtn.textContent = 'Click again to confirm';
      resetBtn.classList.add('chronicle-reset__btn--armed');
      resetTimeout = setTimeout(() => {
        resetArmed = false;
        resetBtn.textContent = 'Reset reading history';
        resetBtn.classList.remove('chronicle-reset__btn--armed');
      }, 3000);
    }
  });
</script>

