---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const loreEntries = await getCollection('lore');

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

const categoryLabels: Record<string, string> = {
  location: 'Location',
  faction:  'Faction',
  concept:  'Concept',
  creature: 'Creature',
};
---

<BaseLayout
  title="The World"
  description="The world of the Solis Lantern Chronicles: three tiers, the Great Walls, Leviathans, and Brinegate."
>
  <div class="world-page-wrap">

    <div class="world-header">
      <div class="world-header__left">
        <p class="world-header__eyebrow">Chronicle Lore</p>
        <h1 class="world-header__title">The World</h1>
        <p class="world-header__intro">
          A civilization organized around annual catastrophe. Three tiers, two Walls,
          and the sea — always eight days east, always approaching.
        </p>
      </div>
    </div>

    <div class="cat-filter">
      <button class="cat-btn active" data-filter="all">All</button>
      <button class="cat-btn" data-filter="location">Locations</button>
      <button class="cat-btn" data-filter="creature">Creatures</button>
      <button class="cat-btn" data-filter="faction">Factions</button>
      <button class="cat-btn" data-filter="concept">Concepts</button>
    </div>

    <div class="lore-grid" id="lore-grid">
      {loreEntries.map(entry => (
        <a href={resolveHref(`/lore/${entry.id}`)} class="lore-card" data-cat={entry.data.category}>
          <span class="lore-card__ghost" aria-hidden="true">{entry.data.title[0]}</span>
          <span class="lore-card__cat">{categoryLabels[entry.data.category]}</span>
          <h2 class="lore-card__title">{entry.data.title}</h2>
          <p class="lore-card__summary">{entry.data.summary}</p>
          <div class="lore-card__footer">
            <span class="lore-card__read">Read entry &rarr;</span>
          </div>
        </a>
      ))}
    </div>

  </div>

  <script>
    document.querySelectorAll('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = (btn as HTMLButtonElement).dataset.filter;
        document.querySelectorAll<HTMLElement>('.lore-card').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.cat === filter) ? 'flex' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
