---
import '../styles/global.css';
import { Image } from 'astro:assets';
import lanternLogo from '../assets/lantern-logo-new.png';

interface Props {
  title?: string;
  description?: string;
  fullscreenHero?: boolean;
  ogType?: string;
  ogImage?: string;
}

const {
  title = 'Solis Lantern Chronicles',
  description = 'A chronicle of an ongoing homebrew TTRPG campaign.',
  fullscreenHero = false,
  ogType = 'website',
  ogImage,
} = Astro.props;

const pathname = cleanPath(new URL(Astro.request.url).pathname);
function cleanPath(path: string) {
  const trimmed = path.replace(/\/+$|^$/g, '');
  return trimmed === '' ? '/' : trimmed;
}
const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}
function isActive(href: string) {
  const resolved = resolveHref(href);
  return pathname === resolved || pathname.startsWith(`${resolved}/`);
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const pageTitle = title === 'Solis Lantern Chronicles' ? title : `${title} — Solis Lantern Chronicles`;
const siteOrigin = (Astro.site?.href ?? '/').replace(/\/$/, '');
const ogImageURL = ogImage ?? (siteOrigin + resolveHref('/og-social-card.png'));
const siteRoot = siteOrigin + SITE_BASE;

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Solis Lantern Chronicles',
  url: siteRoot,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <link rel="icon" type="image/png" sizes="32x32" href={resolveHref('/favicon.png')} />
    <!-- Typography: IM Fell English (display) + Crimson Pro (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=IM+Fell+English+SC&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <script type="application/ld+json" is:inline set:html={websiteSchema} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Site navigation">
        <a href={resolveHref('/')} class="nav-home">
          <Image src={lanternLogo} alt="" class="nav-logo" aria-hidden="true" width={32} height={32} loading="eager" />
          <span class="nav-home__text">Solis Lantern Chronicles</span>
        </a>
        <button class="nav-toggle" aria-label="Open navigation" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <ul class="nav-links">
          <li><a href={resolveHref('/chronicle')} aria-current={isActive('/chronicle') ? 'page' : undefined}>Chronicle</a></li>
          <li><a href={resolveHref('/characters')} aria-current={isActive('/characters') ? 'page' : undefined}>Characters</a></li>
          <li><a href={resolveHref('/world')} aria-current={isActive('/world') ? 'page' : undefined}>World</a></li>
          <li><a href={resolveHref('/npcs')} aria-current={isActive('/npcs') ? 'page' : undefined}>People</a></li>
        </ul>
      </nav>
    </header>

    <script>
      const header = document.querySelector('.site-header') as HTMLElement;
      const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
      const links = document.querySelectorAll('.nav-links a');

      toggle?.addEventListener('click', () => {
        const isOpen = header.classList.toggle('nav-open');
        toggle.setAttribute('aria-expanded', String(isOpen));
        toggle.setAttribute('aria-label', isOpen ? 'Close navigation' : 'Open navigation');
      });

      links.forEach(link => {
        link.addEventListener('click', () => {
          header.classList.remove('nav-open');
          toggle?.setAttribute('aria-expanded', 'false');
          toggle?.setAttribute('aria-label', 'Open navigation');
        });
      });
    </script>

    <main class:list={[{ 'has-fullscreen-hero': fullscreenHero }]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span class="site-footer__copy">&copy; {new Date().getFullYear()} Solis Lantern Chronicles</span>
        <a href="mailto:solislanternchronicles@gmail.com" class="site-footer__contact">Contact</a>
      </div>
    </footer>
  </body>
</html>
