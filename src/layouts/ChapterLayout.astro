---
/**
 * ChapterLayout.astro
 * Wraps a chapter page in the full reading experience:
 *   - Settings toggles (gradual text, sound, GM notes)
 *   - Chapter title block (session, title, date)
 *   - PageTurner component (receives chapter body via slot)
 *   - GmNotesToggle + panel
 */
import BaseLayout from './BaseLayout.astro';
import PageTurner from '../components/PageTurner.astro';
import { getCollection } from 'astro:content';
import { CHARACTER_COLORS } from '../lib/characterColors';

interface Props {
  title: string;
  session: number;
  date: Date;
  gmNotes?: string;
}

const { title, session, date, gmNotes } = Astro.props;

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

const allCharacters = await getCollection('characters');
const characterData = allCharacters.map(c => ({
  slug: c.id,
  name: c.data.name,
  color: CHARACTER_COLORS[c.id] ?? '',
  summary: c.data.summary ?? c.data.short_bio,
  href: resolveHref(`/characters/${c.id}`),
}));

---

<BaseLayout title={title}>
  <Fragment slot="head">
    {Array.from({ length: 12 }, (_, i) => (
      <link rel="prefetch" href={`${SITE_BASE}assets/dice-box/sounds/dicehit/dicehit_wood${i + 1}.mp3`} as="fetch" crossorigin="anonymous" />
    ))}
    <script is:inline>
      (function () {
        var s = parseFloat(localStorage.getItem('reader-font-scale'));
        if (!isNaN(s) && s !== 1) document.documentElement.style.setProperty('--reader-font-scale', s);
      })();
    </script>
  </Fragment>
  <div class="chapter-reader">

    <!-- Controls bar: back link + reader settings -->
    <div class="chapter-controls">
      <a href={resolveHref('/chronicle')} class="chapter-controls__back">← Chronicle</a>
      <div class="chapter-controls__toggles">
        <div class="text-group">
          <button
            class="toggle-btn text-group__main"
            aria-expanded="false"
            aria-controls="text-submenu"
            title="Text settings"
          >Text</button><button
            class="toggle-btn text-group__caret"
            aria-expanded="false"
            aria-controls="text-submenu"
            title="Text settings"
          >▾</button>
          <div id="text-submenu" class="text-group__menu" hidden>
            <div class="text-row">
              <button
                id="toggle-gradual"
                class="toggle-btn"
                aria-pressed="true"
                title="Toggle word-by-word text reveal"
              >Gradual</button>
            </div>
            <div class="text-row">
              <button
                id="toggle-save-progress"
                class="toggle-btn"
                aria-pressed="true"
                title="Save reading position between visits"
              >Save progress</button>
            </div>
            <div class="font-size-row">
              <button id="font-size-decrease" class="toggle-btn font-size-btn" aria-label="Decrease font size">−</button>
              <button id="font-size-reset"    class="toggle-btn font-size-btn" aria-label="Reset font size">A</button>
              <button id="font-size-increase" class="toggle-btn font-size-btn" aria-label="Increase font size">+</button>
            </div>
            <div class="font-size-row">
              <button id="reveal-speed-decrease" class="toggle-btn font-size-btn" aria-label="Slower text reveal">−</button>
              <button id="reveal-speed-reset"    class="toggle-btn font-size-btn" aria-label="Reset reveal speed">1×</button>
              <button id="reveal-speed-increase" class="toggle-btn font-size-btn" aria-label="Faster text reveal">+</button>
            </div>
            <form id="go-to-form" class="go-to-row" novalidate>
              <input
                type="number"
                id="go-to-input"
                class="go-to-input"
                min="1"
                placeholder="Page #"
                aria-label="Go to page number"
              >
              <button type="submit" class="toggle-btn">Go</button>
            </form>
          </div>
        </div>
        <div class="sound-group">
          <button
            id="toggle-sound"
            class="toggle-btn sound-group__main"
            aria-pressed="true"
            title="Toggle all sound"
          >Sound</button><button
            class="toggle-btn sound-group__caret"
            aria-expanded="false"
            aria-controls="sound-submenu"
            title="Individual sound settings"
          >▾</button>
          <div id="sound-submenu" class="sound-group__menu" hidden>
            <div class="sound-row">
              <button id="toggle-writing-sound" class="toggle-btn" aria-pressed="true">Writing</button>
              <input type="range" id="writing-sound-volume" class="sound-vol" min="0" max="1" step="0.05" value="0.6" aria-label="Writing sound volume">
            </div>
            <div class="sound-row">
              <button id="toggle-dice-sound" class="toggle-btn" aria-pressed="true">Dice</button>
              <input type="range" id="dice-sound-volume" class="sound-vol" min="0" max="1" step="0.05" value="0.8" aria-label="Dice sound volume">
            </div>
            <div class="sound-row">
              <button id="toggle-ambience-sound" class="toggle-btn" aria-pressed="true">Ambience</button>
              <input type="range" id="ambience-volume" class="sound-vol" min="0" max="1" step="0.05" value="0.15" aria-label="Ambience volume">
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Page surface — the visual centrepiece -->
    <PageTurner title={title} session={session} date={date}>
      <slot />
    </PageTurner>

    <!-- GM notes panel — hidden until toggled; only rendered if gmNotes exists -->
    {gmNotes && (
      <div id="gm-notes-panel">
        <p class="gm-notes__heading">GM Notes</p>
        <div class="gm-notes__body">
          <!-- TODO: render gmNotes as markdown when a chapter has notes -->
          <p>{gmNotes}</p>
        </div>
      </div>
    )}

  </div>
</BaseLayout>

<script type="application/json" id="character-data" is:inline set:html={JSON.stringify(characterData)} />

<script>
  import { initPageTurner } from '../scripts/page-turner.js';
  import { initSketchReveal } from '../scripts/sketch-reveal.js';
  import { replaceCharacterMentions } from '../scripts/character-mentions';
  import { initLoreTooltips } from '../scripts/lore-tooltips';

  // Replace character names in #pt-source BEFORE initPageTurner reads it to
  // build the pages array — this way spans are baked into the stored HTML
  // strings and survive the word-reveal wrapping that happens per page display.
  replaceCharacterMentions();

  initPageTurner();

  // Init tooltips after each page is shown (fresh DOM nodes, no data-lore-init).
  // DOMContentLoaded is handled by Lore.astro's script for the initial page.
  document.addEventListener('page-turner:page-changed', initLoreTooltips);

  document.addEventListener('page-turner:text-revealed', () => {
    const page = document.getElementById('pt-page');
    if (page) initSketchReveal(page);
  });
</script>
