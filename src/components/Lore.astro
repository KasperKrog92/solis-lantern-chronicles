---
/**
 * Lore.astro
 * Inline tooltip that pulls content from characters/, npcs/, or lore/ collections.
 *
 * Usage in MDX:
 *   <Lore slug="mara-embervale">Mara</Lore>
 *   <Lore slug="brinegate">Brinegate</Lore>
 *
 * If no entry is found for the slug, renders children as plain text.
 */
import { getCollection } from 'astro:content';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL;

const [allCharacters, allNpcs, allLore] = await Promise.all([
  getCollection('characters'),
  getCollection('npcs'),
  getCollection('lore'),
]);

const charEntry   = allCharacters.find(e => e.id === slug);
const npcEntry    = allNpcs.find(e => e.id === slug);
const loreEntry   = allLore.find(e => e.id === slug);

let name    = '';
let summary = '';
let href    = '';
let found   = false;

if (charEntry) {
  found   = true;
  name    = charEntry.data.name;
  summary = charEntry.data.summary ?? charEntry.data.short_bio;
  href    = `${base}characters/${slug}`;
} else if (npcEntry) {
  found   = true;
  name    = npcEntry.data.name;
  summary = npcEntry.data.summary ?? npcEntry.data.description;
  href    = `${base}npcs/${slug}`;
} else if (loreEntry) {
  found   = true;
  name    = loreEntry.data.title;
  summary = loreEntry.data.summary;
  href    = `${base}lore/${slug}`;
} else {
  console.warn(`[Lore] No entry found for slug: "${slug}" — rendering as plain text.`);
}
---

{found ? (
  <span class="lore-link" data-lore-slug={slug}>
    <slot />
    <span class="lore-tooltip" role="tooltip">
      <span class="lore-tooltip__name">{name}</span>
      <span class="lore-tooltip__summary">{summary}</span>
      <a href={href} class="lore-tooltip__link">→ full entry</a>
    </span>
  </span>
) : (
  <slot />
)}

<style>
  .lore-link {
    position: relative;
    display: inline;
    border-bottom: 1px dotted currentColor;
    cursor: default;
  }

  /* Tooltip — hidden until hover or .tooltip-open (tap) */
  .lore-tooltip {
    display: none;
    position: absolute;
    left: 50%;
    bottom: calc(100% + 8px);
    transform: translateX(-50%);
    width: 220px;
    background: #f5ead8;
    color: #2a1f0e;
    border: 1px solid #c8a84b;
    border-radius: 3px;
    padding: 0.65em 0.8em;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.35);
    z-index: 200;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 0.875rem;
    line-height: 1.45;
    white-space: normal;
    text-align: left;
  }

  /* Show on hover (desktop) or when JS adds .tooltip-open (tap) */
  .lore-link:hover .lore-tooltip,
  .lore-link.tooltip-open .lore-tooltip {
    display: block;
  }

  /* Flip below when there isn't room above (JS adds .tooltip-below) */
  .lore-link.tooltip-below .lore-tooltip {
    bottom: auto;
    top: calc(100% + 8px);
  }

  /*
   * Transparent bridge that fills the gap between the tooltip box and the
   * trigger text. Without this, the cursor falls into empty space while
   * travelling from text to tooltip, the :hover state drops, and the
   * tooltip vanishes before the link can be clicked.
   */
  .lore-tooltip::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -10px;
    height: 10px;
  }

  .lore-link.tooltip-below .lore-tooltip::before {
    bottom: auto;
    top: -10px;
  }

  .lore-tooltip__name {
    display: block;
    font-style: italic;
    font-weight: 600;
    margin-bottom: 0.3em;
  }

  .lore-tooltip__summary {
    display: block;
    margin-bottom: 0.55em;
  }

  .lore-tooltip__link {
    display: block;
    color: #8b3a3a;
    text-decoration: none;
    font-size: 0.875em;
  }

  .lore-tooltip__link:hover {
    text-decoration: underline;
  }
</style>

<script>
  function initLoreTooltips() {
    const links = document.querySelectorAll<HTMLElement>('.lore-link');

    links.forEach(link => {
      const tooltip = link.querySelector<HTMLElement>('.lore-tooltip');
      if (!tooltip) return;

      // Smart positioning: flip below if not enough room above
      link.addEventListener('mouseenter', () => {
        const rect = link.getBoundingClientRect();
        if (rect.top < 140) {
          link.classList.add('tooltip-below');
        } else {
          link.classList.remove('tooltip-below');
        }
      });

      // Tap toggle for mobile
      link.addEventListener('click', e => {
        // Let the → link navigate normally
        if ((e.target as HTMLElement).closest('.lore-tooltip__link')) return;
        e.stopPropagation();
        link.classList.toggle('tooltip-open');
      });
    });

    // Dismiss open tooltip when tapping elsewhere
    document.addEventListener('click', () => {
      document.querySelectorAll('.lore-link.tooltip-open').forEach(el => {
        el.classList.remove('tooltip-open');
      });
    });
  }

  // Run once on load; re-run if page-turner swaps pages
  document.addEventListener('DOMContentLoaded', initLoreTooltips);
  document.addEventListener('page-turner:page-changed', initLoreTooltips);
</script>
