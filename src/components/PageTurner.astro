---
/**
 * PageTurner.astro
 * The core reading component. Receives the chapter's rendered body as a slot,
 * hides it in #pt-source, and lets page-turner.js split it on <hr> elements
 * and present pages one at a time.
 */

interface Props {
  title: string;
  session: number;
  date: Date;
}

const { title, session, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<div id="pt-container">
  <div class="pt-stage" id="pt-stage">
  <div class="pt-track" id="pt-track">
  <div class="page-surface">
    <div class="page-surface__canvas" aria-hidden="true">
      <div class="page-surface__parchment" id="pt-parchment"></div>
    </div>

    <!--
      Source container: hidden, holds the full rendered markdown body.
      JavaScript reads from here, splits on <hr> elements (from --- in markdown),
      and populates #pt-page one page at a time.
    -->
    <div id="pt-source" aria-hidden="true">
      <slot />
    </div>

    <!-- Running header — visible on pages 2+; hidden by JS on page 1 -->
    <div class="chapter-running-header" id="pt-running-header" hidden>
      <span class="chapter-running-header__label">{title}</span>
      <span id="pt-counter-header" class="chapter-running-header__counter" aria-live="polite">—</span>
      <div class="chapter-running-header__ornament" aria-hidden="true">
        <div class="chapter-running-header__ornament-line"></div>
        <span class="chapter-running-header__ornament-gem">✦</span>
        <div class="chapter-running-header__ornament-line"></div>
      </div>
    </div>

    <!-- Title block — visible on page 1 only; hidden by JS on subsequent pages -->
    <header class="chapter-page-header" id="pt-title">
      <h1 class="chapter-page-header__title">{title}</h1>
      <p class="chapter-page-header__date">{formattedDate}</p>
    </header>

    <!-- Active page — populated by page-turner.js -->
    <div id="pt-page" class="pt-page-content" aria-live="polite"></div>

  </div>
  </div><!-- /pt-track -->
  </div><!-- /pt-stage -->

  <!-- Navigation footer -->
  <div class="pt-footer">
    <button id="pt-prev" class="pt-nav-btn" aria-label="Previous page">← Prev</button>
    <span id="pt-counter" class="pt-counter" aria-live="polite">1 / 1</span>
    <button id="pt-next" class="pt-nav-btn" aria-label="Next page">Next →</button>
  </div>

  <!-- Navigation shortcut hints — toggled by the ? button or ? key -->
  <div id="pt-shortcuts" class="pt-shortcuts" hidden role="dialog" aria-label="Navigation shortcuts">
    <p class="pt-shortcuts__heading">Navigation</p>
    <dl class="pt-shortcuts__list">
      <div class="pt-shortcuts__row">
        <dt>Arrow keys</dt>
        <dd>← / → — previous / next page</dd>
      </div>
      <div class="pt-shortcuts__row">
        <dt>Click left / right</dt>
        <dd>Turn the page</dd>
      </div>
      <div class="pt-shortcuts__row">
        <dt>Click middle</dt>
        <dd>Instant text reveal</dd>
      </div>
      <div class="pt-shortcuts__row">
        <dt>Swipe</dt>
        <dd>Left / right to turn pages</dd>
      </div>
    </dl>
    <p class="pt-shortcuts__dismiss">Press <kbd>?</kbd> or <kbd>Esc</kbd> to close</p>
  </div>
</div>
