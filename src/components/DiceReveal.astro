---
/**
 * DiceReveal.astro
 * A reusable skill-check reveal component for use in MDX chapter files.
 *
 * When the reader reaches a dice reveal in the prose:
 *   1. The card appears with character name, skill, DC, and modifier
 *   2. The reader clicks "Roll" to trigger the animation
 *   3. The d20 result animates in (random values, then settles on the roll)
 *   4. The outcome text appears
 *
 * No dice reveals are present in Session 00, but the component is complete
 * and ready to be embedded in future chapters via MDX shortcode:
 *
 *   <DiceReveal
 *     character="Mara"
 *     skill="Investigation"
 *     dc={12}
 *     modifier={+4}
 *     outcome="The workshop ransacking is methodical, not frantic."
 *   />
 */

interface Props {
  character: string;
  skill: string;
  dc: number;
  modifier: number;
  outcome: string;
}

const { character, skill, dc, modifier, outcome } = Astro.props;
const modStr = modifier >= 0 ? `+${modifier}` : `${modifier}`;
---

<div class="dice-reveal" data-outcome={outcome}>
  <div class="dice-reveal__header">
    {character} — {skill} · DC {dc} · Roll {modStr}
  </div>
  <button class="dice-reveal__roll-btn" type="button">Roll the dice</button>
  <div class="dice-reveal__result" role="status" aria-live="polite">
    <div class="dice-reveal__die" aria-hidden="true"></div>
    <div class="dice-reveal__outcome">{outcome}</div>
  </div>
</div>

<script>
  // Self-contained: each DiceReveal initialises independently
  document.querySelectorAll<HTMLElement>('.dice-reveal').forEach(el => {
    const btn     = el.querySelector<HTMLButtonElement>('.dice-reveal__roll-btn');
    const result  = el.querySelector<HTMLElement>('.dice-reveal__result');
    const dieEl   = el.querySelector<HTMLElement>('.dice-reveal__die');

    if (!btn || !result || !dieEl) return;

    btn.addEventListener('click', () => {
      btn.disabled = true;

      // Roll result (d20, 1–20)
      const roll = Math.floor(Math.random() * 20) + 1;

      // Tumbling animation: rapid random numbers for 700ms, then settle
      let ticker = 0;
      const interval = setInterval(() => {
        dieEl.textContent = String(Math.floor(Math.random() * 20) + 1);
        ticker++;
      }, 60);

      setTimeout(() => {
        clearInterval(interval);
        dieEl.textContent = String(roll);
        result.classList.add('visible');
      }, 700);
    }, { once: true });
  });
</script>
