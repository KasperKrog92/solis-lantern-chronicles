---
/**
 * DiceReveal.astro
 * A skill-check reveal component for MDX chapter files.
 *
 * The `result` prop is the actual historical roll from the session —
 * the outcome is predetermined. The animation simulates the feel of
 * rolling, but always lands on the specified result.
 *
 * All interactivity is handled by initDiceReveals() in page-turner.js,
 * which also gates forward navigation until the roll resolves.
 *
 * Shortcode usage:
 *   <DiceReveal
 *     character="Mara"
 *     skill="Insight"
 *     dc={14}
 *     modifier={5}
 *     result={14}
 *     outcome="The figure's shadow falls the wrong way. Whatever is wearing Kisara's face, it is not Kisara."
 *   />
 */

interface Props {
  character: string;
  skill: string;
  dc: number;
  modifier: number;
  result: number;   // Fixed historical roll (1–20)
  outcome: string;  // Narrative text revealed after the roll
}

const { character, skill, dc, modifier, result, outcome } = Astro.props;
const modStr = modifier >= 0 ? `+${modifier}` : `${modifier}`;
---

<div
  class="dice-reveal"
  data-result={result}
  data-dc={dc}
  data-modifier={modifier}
>
  <div class="dice-reveal__header">
    {character} — {skill} · DC {dc} · Roll {modStr}
  </div>

  <!-- Pre-roll state: button visible, tumble hidden -->
  <div class="dice-reveal__pre-roll">
    <button class="dice-reveal__roll-btn" type="button">Roll the dice</button>
  </div>

  <!-- Tumbling state: shown the moment the button is clicked.
       During tumble: only .dice-reveal__die is visible, large and centred.
       After settling: JS adds .expanded to .dice-reveal__equation — the die
       shrinks left and .dice-reveal__addition fades in showing the total. -->
  <div class="dice-reveal__tumble" aria-hidden="true">
    <div class="dice-reveal__equation">
      <div class="dice-reveal__roll-part">
        <div class="dice-reveal__die"></div>
        <div class="dice-reveal__die-label"></div>
      </div>
      <div class="dice-reveal__addition">
        <span class="dice-reveal__operator"></span>
        <span class="dice-reveal__total"></span>
      </div>
    </div>
  </div>

  <!-- Outcome: fades in 300ms after the die settles -->
  <div class="dice-reveal__result" role="status" aria-live="polite">
    <div class="dice-reveal__outcome">{outcome}</div>
  </div>
</div>
