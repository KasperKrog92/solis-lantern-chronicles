---
/**
 * CharacterChip.astro
 * A small character indicator used in chapter listings.
 * Shows a badge with initials and the character's name, linking to their page.
 */

import { CHARACTER_COLORS } from '../lib/characterColors';

interface Props {
  slug: string;
  name: string;
}

const { slug, name } = Astro.props;

const SITE_BASE = '/solis-lantern-chronicles/';
function resolveHref(href: string) {
  const target = href === '/' ? SITE_BASE : href.replace(/^\/+/, '');
  return new URL(target, `https://example.com${SITE_BASE}`).pathname;
}

// Derive initial from first name only (matches the displayed label)
function initials(n: string): string {
  return n.split(' ')[0][0]?.toUpperCase() ?? '';
}
---

<a href={resolveHref(`/characters/${slug}`)} class="char-chip" style={`--char-accent: ${CHARACTER_COLORS[slug] ?? 'var(--ink)'}`} title={name}>
  <span class="char-chip__badge" aria-hidden="true">{initials(name)}</span>
  {name.split(' ')[0]}
</a>
