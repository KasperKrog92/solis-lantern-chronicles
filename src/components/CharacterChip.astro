---
/**
 * CharacterChip.astro
 * A small character indicator used in chapter listings.
 * Shows a badge with initials and the character's name, linking to their page.
 */

interface Props {
  slug: string;
  name: string;
}

const { slug, name } = Astro.props;

const SITE_BASE = import.meta.env.SITE
  ? new URL(import.meta.env.SITE).pathname.replace(/\/$/, '') || '/'
  : '/solis-lantern-chronicles';
const resolveHref = (href: string) => href === '/' ? SITE_BASE : `${SITE_BASE}${href}`;

// Derive initials from name: first letter of each word, max 2 characters
function initials(n: string): string {
  return n
    .split(' ')
    .map(w => w[0]?.toUpperCase() ?? '')
    .filter(Boolean)
    .join('')
    .slice(0, 2);
}
---

<a href={resolveHref(`/characters/${slug}`)} class="char-chip" title={name}>
  <span class="char-chip__badge" aria-hidden="true">{initials(name)}</span>
  {name.split(' ')[0]}
</a>
